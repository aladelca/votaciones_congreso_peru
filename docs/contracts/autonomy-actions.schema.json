{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autocodex.dev/contracts/autonomy-actions.schema.json",
  "title": "autocodex autonomy actions",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "summary", "next"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "next": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["bead", "none"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {"const": "bead"}
            }
          },
          "then": {
            "required": ["id"]
          }
        }
      ]
    },
    "updates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "beads": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "status"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": ["todo", "in_progress", "review", "done", "blocked"]
              },
              "note": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "create_beads": {
      "type": "array",
      "items": {
        "$ref": "autonomy-tasks.schema.json#/definitions/task"
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "review_required": {
          "type": "boolean"
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking": {
          "type": "boolean"
        }
      }
    },
    "stop": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason"],
          "properties": {
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "details": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}
